page {
  background: #f6f7f2;
  color: #17231f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 28rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5e7dc;
  border-radius: 8rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(23, 35, 31, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.name {
  color: #17231f;
  font-size: 30rpx;
  font-weight: 700;
}

.label {
  display: block;
  margin: 22rpx 0 10rpx;
  color: #34423c;
  font-size: 24rpx;
  font-weight: 600;
}

input,
textarea,
picker {
  width: 100%;
  min-height: 84rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #d7dbcf;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: #ffffff;
  font-size: 28rpx;
}

textarea {
  min-height: 150rpx;
}

button {
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.primary {
  color: #ffffff;
  background: #0f766e;
}

.secondary {
  color: #17231f;
  background: #e9ece3;
}

.ghost {
  color: #92400e;
  background: #fff4d6;
}

.row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.row > button {
  flex: 1;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  margin: 8rpx 8rpx 0 0;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #e7f5f2;
  color: #0f766e;
  font-size: 22rpx;
}

.muted {
  color: #667085;
}

.stat-row {
  display: flex;
  gap: 16rpx;
}

.stat {
  flex: 1;
  padding: 18rpx;
  border: 1rpx solid #e5e7dc;
  border-radius: 8rpx;
  background: #fbfcf7;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 800;
}
