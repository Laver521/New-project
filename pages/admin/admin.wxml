<view class="page">
  <view class="section">
    <view class="title">运营概览</view>
    <view class="subtitle">用于演示平台活跃度、交易状态和待处理内容。</view>
  </view>

  <view class="panel section">
    <view class="stat-row">
      <view class="stat">
        <view class="stat-value">2,418</view>
        <view class="subtitle">注册卡友</view>
      </view>
      <view class="stat">
        <view class="stat-value">386</view>
        <view class="subtitle">在售卡片</view>
      </view>
      <view class="stat">
        <view class="stat-value">74</view>
        <view class="subtitle">今日交流</view>
      </view>
    </view>
  </view>

  <view class="panel section" wx:for="{{tasks}}" wx:key="title">
    <view class="name">{{item.title}}</view>
    <view class="subtitle">{{item.desc}}</view>
    <view class="row actions">
      <button class="primary" bindtap="resolveTask" data-title="{{item.title}}">处理</button>
      <button class="secondary" bindtap="ignoreTask">稍后</button>
    </view>
  </view>
</view>
