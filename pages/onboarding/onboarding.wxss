.upload-box {
  display: flex;
  height: 300rpx;
  align-items: center;
  justify-content: center;
  margin: 28rpx 0;
  border: 2rpx dashed #b9c7be;
  border-radius: 8rpx;
  background: #fbfcf7;
  text-align: center;
}

.upload-icon {
  margin: 0 auto 10rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e7f5f2;
  color: #0f766e;
  font-size: 54rpx;
  line-height: 66rpx;
  font-weight: 300;
}

.preview {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}
